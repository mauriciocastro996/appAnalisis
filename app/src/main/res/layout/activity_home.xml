<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTROL ZERO"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Dashboard"/>

        <Button
            android:id="@+id/btnPersonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 Personal"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnUsuarioSistema"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 Usuario Sistema"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnGrupoTrabajo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛠 Grupo de Trabajo"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnRegistroPruebas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧪 Registro de Pruebas"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📈 Historial y Monitoreo"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnReportes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📑 Reportes"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnAlertas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚨 Alertas"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnConfiguraciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙ Configuraciones"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnAuditoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Auditoría"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚪 Cerrar Sesión"
            android:backgroundTint="#F44336"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>

