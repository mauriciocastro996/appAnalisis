<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F9"
    android:padding="24dp">

    <!-- TITULO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asistente Educativo 🤖"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona una materia"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="20dp"/>

    <!-- BOTONES -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMatematicas"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Matemáticas"
        android:textColor="#FFFFFF"
        app:backgroundTint="#3949AB"
        android:layout_marginBottom="10dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHistoria"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Historia"
        android:textColor="#FFFFFF"
        app:backgroundTint="#6D4C41"
        android:layout_marginBottom="10dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCiencia"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Ciencia"
        android:textColor="#FFFFFF"
        app:backgroundTint="#00897B"
        android:layout_marginBottom="10dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLenguaje"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Lenguaje"
        android:textColor="#FFFFFF"
        app:backgroundTint="#8E24AA"
        android:layout_marginBottom="10dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFisica"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Física"
        android:textColor="#FFFFFF"
        app:backgroundTint="#F4511E"
        android:layout_marginBottom="10dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOtros"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Otros"
        android:textColor="#FFFFFF"
        app:backgroundTint="#546E7A"/>

</LinearLayout>